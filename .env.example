# Broker: "tradelocker" (default) or "metaapi"
BROKER=tradelocker

# ── TradeLocker API credentials (required when BROKER=tradelocker) ──
TRADELOCKER_EMAIL=your_email@example.com
TRADELOCKER_PASSWORD=your_password
TRADELOCKER_SERVER=demo           # "demo" or "live"
TRADELOCKER_ACCOUNT_ID=0          # account index (0 for first account)

# ── MetaApi Cloud credentials (required when BROKER=metaapi) ──
# Get your API token at https://app.metaapi.cloud/token
METAAPI_API_KEY=
METAAPI_ACCOUNT_ID=

# OpenRouter / LLM (REQUIRED)
# To use a local model: set LLM_BASE_URL and LLM_API_KEY
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=openrouter/healer-alpha
LLM_BASE_URL=
LLM_API_KEY=

# ForexFactory — optional, agent can work without news
FOREX_FACTORY_URL=https://www.forexfactory.com

# Telegram (OPTIONAL — for notifications + chat control)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# Safety mode — set "true" for paper trading, "false" for real money
DRY_RUN=true

# Risk overrides (optional — defaults come from user-config.json)
# MAX_DAILY_LOSS_PCT=4
# MAX_TOTAL_LOSS_PCT=8
# PROFIT_TARGET_PCT=4
